# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# ── SSH-Wrapper (pve.sh) ──────────────────────────────────────────────
export PVE_HOST="10.10.11.111"
export PVE_USER="root"
export PVE_PASS="CHANGE_ME"
export PVE_HOSTKEY="SHA256:CHANGE_ME"

# ── App-Login für die Smoke-Tests (deploy/test/) ─────────────────────
export APP_EMAIL="you@example.com"
export APP_PASS="CHANGE_ME"

# ── provision.sh (From-Zero-Rebuild, läuft auf dem Proxmox-Host) ─────
# Container
export WEB_CTID="104"
export DB_CTID="105"
export WEB_IP="10.10.11.104"
export DB_IP="10.10.11.105"
export CIDR="23"
export GATEWAY="10.10.10.1"
export BRIDGE="vmbr0"
export STORAGE="local-lvm"
export NAMESERVER="1.1.1.1 9.9.9.9"
export TEMPLATE="debian-12-standard_12.12-1_amd64.tar.zst"
# DB
export DB_NAME="notes_app"
export DB_USER="notes_app"
# Erster Admin-User (optional — sonst manuell via admin-tool.js)
export ADMIN_EMAIL="you@example.com"
export ADMIN_PASS="CHANGE_ME_min8"
# Cloudflare Tunnel-Token (optional — sonst cloudflared manuell, siehe cloudflare-setup.sh)
export CLOUDFLARE_TUNNEL_TOKEN=""

# ── cloudflare-setup.sh (Tunnel + DNS + Access via API) ──────────────
export CF_API_TOKEN="CHANGE_ME"          # Cloudflare API Token: Tunnel:Edit + DNS:Edit (+ Access:Edit optional)
export CF_DOMAIN="example.com"           # deine bei Cloudflare verwaltete Domain
export CF_SUBDOMAIN="notes"              # ergibt notes.example.com
export CF_TUNNEL_NAME="notes-app"
export CF_ACCESS_EMAILS="you@example.com" # komma-getrennte erlaubte E-Mails für die Access-Policy
