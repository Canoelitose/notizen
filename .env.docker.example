# Docker-Variante — nach .env kopieren und ausfüllen:  cp .env.docker.example .env
# .env ist gitignored. Niemals echte Passwörter committen.

# ── Datenbank (mitgelieferter db-Service) ────────────────────────────
DB_NAME=notes_app
DB_USER=notes_app
DB_PASS=BITTE_AENDERN            # Passwort der mitgelieferten PostgreSQL

# ── App ──────────────────────────────────────────────────────────────
APP_PORT=3000                    # Host-Port -> http://localhost:3000
COOKIE_SECURE=0                  # 1, sobald hinter HTTPS/Cloudflare-Tunnel

# Office->PDF-Vorschau ins Image bauen? (true = großes Image mit LibreOffice)
INCLUDE_OFFICE=false

# ── Erst-Admin (nur beim ersten Start angelegt) ──────────────────────
ADMIN_EMAIL=you@example.com
ADMIN_PASS=BITTE_AENDERN_min8

# ── Variante A: entfernte DB direkt per IP/Host ──────────────────────
# DATABASE_URL setzen und nur die App starten:  docker compose up -d app
# DATABASE_URL=postgres://notes_app:PASS@10.10.11.105:5432/notes_app

# ── Variante B: entfernte DB per Cloudflare-Tunnel ───────────────────
# Profil tunnel-db nutzen (Sidecar 'db-tunnel'):
#   docker compose --profile tunnel-db up -d
# DB_TUNNEL_HOSTNAME=db.example.com
# DATABASE_URL=postgres://notes_app:PASS@db-tunnel:5432/notes_app

# ── App per Cloudflare-Tunnel veröffentlichen (Profil tunnel-web) ────
# CLOUDFLARE_TUNNEL_TOKEN=
